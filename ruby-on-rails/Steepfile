# frozen_string_literal: true

D = Steep::Diagnostic

# rbs-inline walks the bundled gems under vendor/ and dumps mirror signatures
# into sig/generated/vendor/. Those duplicate gems whose real signatures come
# from the RBS collection and reference gem-internal types that do not resolve
# (RBS::UnknownTypeName). They are gitignored noise, so load every generated
# subtree except `vendor/`.
non_vendor = lambda do |root|
  Dir.glob("#{root}/*").reject { |path| File.basename(path) == 'vendor' }.sort
end

# Rails framework signatures come from the RBS collection (rbs_collection.yaml),
# Rails route helpers from sig/rbs_rails (generated by `rake rbs_rails:all`),
# and application code from sig/generated (generated by rbs-inline).
#
# `app` and `spec` are separate targets so the permissive RSpec DSL shim
# (sig/rspec) only relaxes the specs, never the application code.

target :app do
  check 'app'

  non_vendor.call('sig/generated').each { |path| signature path }
  signature 'sig/rbs_rails'
  signature 'sig/handwritten'

  library 'json'
  library 'net-http'

  configure_code_diagnostics(D::Ruby.default)
end

target :spec do
  check 'spec'

  non_vendor.call('sig/generated').each { |path| signature path }
  signature 'sig/rbs_rails'
  signature 'sig/handwritten'
  signature 'sig/rspec'

  library 'json'
  library 'net-http'

  configure_code_diagnostics(D::Ruby.default)
end
